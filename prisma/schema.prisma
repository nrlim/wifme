// This is your Prisma schema file
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  JAMAAH
  MUTHAWIF
  AMIR
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum Location {
  MAKKAH
  MADINAH
  BOTH
}

enum VerificationStatus {
  PENDING
  REVIEW
  VERIFIED
  REJECTED
}

enum AvailabilityStatus {
  AVAILABLE
  BOOKED
  OFF
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  photoUrl  String?
  role      Role     @default(JAMAAH)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile            MuthawifProfile?
  bookingsAsJamaah   Booking[]        @relation("JamaahBookings")
  bookingsAsMuthawif Booking[]        @relation("MuthawifBookings")
  tripPackages       TripPackage[]    @relation("MuthawifPackages")
  reviewsGiven       Review[]         @relation("ReviewsGiven")
  wallet             Wallet?
  sentMessages       ChatMessage[]    @relation("SentMessages")
}

model MuthawifProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio                String?
  basePrice          Float              @default(500000)
  operatingAreas     String[]           @default([])
  experience         Int                @default(0)
  languages          String[]           @default(["Indonesia"])
  specializations    String[]           @default([])
  rating             Float              @default(0)
  totalReviews       Int                @default(0)
  documentsUrl       String[]           @default([])
  isAvailable        Boolean            @default(false)
  verificationStatus VerificationStatus @default(PENDING)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  availability Availability[]
  reviews      Review[]
}

model Availability {
  id        String             @id @default(cuid())
  profileId String
  profile   MuthawifProfile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  date      DateTime           @db.Date
  status    AvailabilityStatus @default(AVAILABLE)
  timeSlots String[]           @default([])
  createdAt DateTime           @default(now())

  @@unique([profileId, date])
}

model Booking {
  id              String        @id @default(cuid())
  jamaahId        String
  muthawifId      String
  jamaah          User          @relation("JamaahBookings", fields: [jamaahId], references: [id])
  muthawif        User          @relation("MuthawifBookings", fields: [muthawifId], references: [id])
  startDate       DateTime
  endDate         DateTime
  status          BookingStatus @default(PENDING)
  totalFee        Float
  baseFee         Float         @default(0)
  discountAmount  Float         @default(0)  // Jumlah diskon yang diterapkan
  promotionId     String?                    // Kode promo yang dipakai (opsional)
  promotion       Promotion?    @relation("BookingPromotion", fields: [promotionId], references: [id])
  notes           String?
  paymentRef      String?
  paymentStatus   String?       @default("UNPAID")
  paymentDeadline DateTime?
  // ── Chat Session Control ──────────────────────────────────────
  // When muthawif closes the chat, chatClosedAt is set.
  // After this point, no new messages can be sent (read-only mode).
  chatClosedAt    DateTime?     // null = active session
  chatClosedByMuthawif Boolean  @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  review        Review?
  transactions  Transaction[]
  chatMessages  ChatMessage[]
}

// ── Trip Package ─────────────────────────────────────────────
// Muthawif creates one package per date-range session.
// All Jamaah whose booking overlaps this range can view it.
model TripPackage {
  id          String   @id @default(cuid())
  muthawifId  String
  muthawif    User     @relation("MuthawifPackages", fields: [muthawifId], references: [id], onDelete: Cascade)
  title       String
  description String?
  startDate   DateTime @db.Date
  endDate     DateTime @db.Date
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  itineraries Itinerary[]

  @@index([muthawifId])
  @@index([startDate, endDate])
}

enum ItineraryStatus {
  PLANNED
  ONGOING
  COMPLETED
}

model Itinerary {
  id           String          @id @default(cuid())
  packageId    String
  package      TripPackage     @relation(fields: [packageId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  startTime    DateTime
  endTime      DateTime
  locationName String?
  status       ItineraryStatus @default(PLANNED)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  logs ServiceLog[]

  @@index([packageId])
}

model ServiceLog {
  id           String     @id @default(cuid())
  itineraryId  String
  itinerary    Itinerary  @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  photoUrl     String?
  notes        String?
  checkInTime  DateTime   @default(now())
  createdAt    DateTime   @default(now())
}

model Review {
  id              String          @id @default(cuid())
  bookingId       String          @unique
  booking         Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  profileId       String
  profile         MuthawifProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  reviewerId      String
  reviewer        User            @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  rating          Int             // 1–5
  comment         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

enum TransactionType {
  PAYMENT_ESCROW         // Uang masuk ke escrow (dari jamaah bayar)
  ESCROW_SETTLEMENT      // Uang pindah dari escrow ke available
  WITHDRAWAL             // Uang ditarik muthawif
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

model Wallet {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  availableBalance Float    @default(0)
  escrowBalance    Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  transactions     Transaction[]
  payouts          Payout[]
}

model Transaction {
  id          String            @id @default(cuid())
  walletId    String
  wallet      Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)
  bookingId   String?           
  booking     Booking?          @relation(fields: [bookingId], references: [id])
  type        TransactionType
  amount      Float
  status      TransactionStatus @default(PENDING)
  referenceId String?           
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Payout {
  id                     String            @id @default(cuid())
  walletId               String
  wallet                 Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)
  amount                 Float
  status                 TransactionStatus @default(PENDING)
  bankName               String
  encryptedAccountNumber String
  accountHolderName      String
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
}

enum FeeType {
  PERCENT
  FLAT
}

// ── Promotion / Discount Engine ──────────────────────────────
enum PromotionType {
  FIXED_AMOUNT  // Potongan nominal langsung (IDR)
  PERCENTAGE    // Potongan persentase dari totalFee
}

enum PromotionStatus {
  ACTIVE
  EXPIRED
  DISABLED
}

model Promotion {
  id               String          @id @default(cuid())
  code             String          @unique
  description      String?
  type             PromotionType
  value            Float           // Nominal (IDR) atau persentase tergantung `type`
  minBookingAmount Float           @default(0)  // Total minimum booking agar promo berlaku
  maxUsage         Int?            // null = unlimited
  usedCount        Int             @default(0)
  expiryDate       DateTime?       // null = tidak ada batas waktu
  status           PromotionStatus @default(ACTIVE)
  discountTarget   String          @default("PLATFORM") // "PLATFORM" | "MUTHAWIF"
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  bookings         Booking[]       @relation("BookingPromotion")

  @@index([code])
  @@index([status])
}

model GlobalSetting {
  id                String   @id @default("singleton")
  feeType           FeeType  @default(PERCENT)
  feeValue          Float    @default(5.0)         // % atau IDR tergantung feeType
  feeComponents     Json     @default("[]")         // array komponen biaya tambahan
  minimumWithdrawal Float    @default(50000)
  supportedLocations String[] @default(["Makkah", "Madinah"])
  supportedServices  String[] @default(["Umrah Reguler", "Badal Umrah", "City Tour"])
  supportedLanguages String[] @default(["Indonesia", "Arab", "Inggris"])
  updatedAt         DateTime @updatedAt
}

// ── Chat (Firebase RTDB Mirror → PostgreSQL Archive) ─────────────
// Firebase RTDB is the source-of-truth for real-time delivery.
// This table is a permanent archive for:
//   1. Audit trail & legal record-keeping
//   2. Zero-downtime migration to PostgreSQL/Socket.io
//   3. Sequence ordering guarantee via sequenceNumber
enum MessageStatus {
  sent
  delivered
}

model ChatMessage {
  id                String        @id @default(cuid())
  bookingId         String
  booking           Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  senderId          String
  sender            User          @relation("SentMessages", fields: [senderId], references: [id])
  content           String
  firebaseMessageId String?       @unique   // Firebase push key — used for upsert/dedup
  sentAt            DateTime                // Parsed from Firebase client timestamp
  sequenceNumber    Int                     // Monotonically increasing per booking
  status            MessageStatus @default(sent)
  archivedAt        DateTime      @default(now())

  @@index([bookingId, sequenceNumber]) // Primary: chat history ordered by seq
  @@index([bookingId, sentAt])         // Secondary: time-based queries
  @@index([senderId])
}
