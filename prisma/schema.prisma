// This is your Prisma schema file
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  JAMAAH
  MUTHAWIF
  AMIR
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum Location {
  MAKKAH
  MADINAH
  BOTH
}

enum VerificationStatus {
  PENDING
  REVIEW
  VERIFIED
  REJECTED
}

enum AvailabilityStatus {
  AVAILABLE
  BOOKED
  OFF
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  photoUrl  String?
  role      Role     @default(JAMAAH)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile            MuthawifProfile?
  bookingsAsJamaah   Booking[]        @relation("JamaahBookings")
  bookingsAsMuthawif Booking[]        @relation("MuthawifBookings")
  reviewsGiven       Review[]         @relation("ReviewsGiven")
  wallet             Wallet?
}

model MuthawifProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio                String?
  basePrice          Float              @default(500000)
  operatingAreas     String[]           @default([])
  experience         Int                @default(0)
  languages          String[]           @default(["Indonesia"])
  specializations    String[]           @default([])
  rating             Float              @default(0)
  totalReviews       Int                @default(0)
  documentsUrl       String[]           @default([])
  isAvailable        Boolean            @default(false)
  verificationStatus VerificationStatus @default(PENDING)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  availability Availability[]
  reviews      Review[]
}

model Availability {
  id        String             @id @default(cuid())
  profileId String
  profile   MuthawifProfile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  date      DateTime           @db.Date
  status    AvailabilityStatus @default(AVAILABLE)
  timeSlots String[]           @default([])
  createdAt DateTime           @default(now())

  @@unique([profileId, date])
}

model Booking {
  id              String        @id @default(cuid())
  jamaahId        String
  muthawifId      String
  jamaah          User          @relation("JamaahBookings", fields: [jamaahId], references: [id])
  muthawif        User          @relation("MuthawifBookings", fields: [muthawifId], references: [id])
  startDate       DateTime
  endDate         DateTime
  status          BookingStatus @default(PENDING)
  totalFee        Float                           // Jamaah pays: baseFee + serviceFee
  baseFee         Float         @default(0)       // Muthawif receives: basePrice × duration
  notes           String?
  paymentRef      String?
  paymentStatus   String?       @default("UNPAID")
  paymentDeadline DateTime?     // auto-cancel if UNPAID past this
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  review          Review?
  transactions    Transaction[]
}

model Review {
  id              String          @id @default(cuid())
  bookingId       String          @unique
  booking         Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  profileId       String
  profile         MuthawifProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  reviewerId      String
  reviewer        User            @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  rating          Int             // 1–5
  comment         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

enum TransactionType {
  PAYMENT_ESCROW         // Uang masuk ke escrow (dari jamaah bayar)
  ESCROW_SETTLEMENT      // Uang pindah dari escrow ke available
  WITHDRAWAL             // Uang ditarik muthawif
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

model Wallet {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  availableBalance Float    @default(0)
  escrowBalance    Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  transactions     Transaction[]
  payouts          Payout[]
}

model Transaction {
  id          String            @id @default(cuid())
  walletId    String
  wallet      Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)
  bookingId   String?           
  booking     Booking?          @relation(fields: [bookingId], references: [id])
  type        TransactionType
  amount      Float
  status      TransactionStatus @default(PENDING)
  referenceId String?           
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Payout {
  id                     String            @id @default(cuid())
  walletId               String
  wallet                 Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)
  amount                 Float
  status                 TransactionStatus @default(PENDING)
  bankName               String
  encryptedAccountNumber String
  accountHolderName      String
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
}

enum FeeType {
  PERCENT
  FLAT
}

model GlobalSetting {
  id                String   @id @default("singleton")
  feeType           FeeType  @default(PERCENT)
  feeValue          Float    @default(5.0)         // % atau IDR tergantung feeType
  feeComponents     Json     @default("[]")         // array komponen biaya tambahan
  minimumWithdrawal Float    @default(50000)
  supportedLocations String[] @default(["Makkah", "Madinah"])
  supportedServices  String[] @default(["Umrah Reguler", "Badal Umrah", "City Tour"])
  supportedLanguages String[] @default(["Indonesia", "Arab", "Inggris"])
  updatedAt         DateTime @updatedAt
}

